#!/bin/sh
# the next line restarts using wish \
    exec vtk "$0" -- "$@"


lappend auto_path [ file dirname [ info script ] ]
lappend auto_path [ file join [file join [ file dirname [ info script ] ] ".." ] base ]
lappend auto_path [ file join [file join [ file dirname [ info script ] ] ".." ] apps ]

package provide bis_nonlinearbrainregister 1.0
package require bis_dualimagealgorithm 1.0
package require bis_linearintensityregister 1.0
package require bis_nonlinearintensityregister 1.0
package require bis_resliceimage 1.0

itcl::class bis_nonlinearbrainregister {

    inherit bis_dualimagealgorithm

    constructor { } {	 $this Initialize  }

    public method Initialize { }
    public method Execute { }
    public method GetGUIName    { } { return "NONLINEARBRAINREGISTER" }
    public method GetExtension { } { return ".nii.gz" }

    #overwrite parent method
    public method UpdateOutputFilenames { } 	
}

# -----------------------------------------------------------------------------------------
# Initialize
# ----------------------------------------------------------------------------------------

itcl::body bis_nonlinearbrainregister::Initialize { } {

    PrintDebug "bis_nonlinearbrainregister::Initialize" 
    
    #commandswitch,description,shortdescription,optiontype,defaultvalue,valuerange,priority
    set options {
	{ 5thpass      "Optional 5thpass of registration, 1.25 is the best but slow and sensitive to stripping error" "5thpass: slow" { listofvalues default }  none { none 2.5mm 2mm 1.25mm }   1}
    }

    set defaultsuffix { "_NONLINEARBRAINREGISTER" }
    set category "Registration"    
    set scriptname bis_nonlinearbrainregister
    set completionstatus "Done"
    
    #
    #document
    #
    
    set description "NONLINEARBRAINREGISTER"
    set description2 "New style brain registration code"
    set backwardcompatibility ""
    set authors "dustin.scheinost@yale.edu"
    
    $this InitializeDualImageAlgorithm
    $this RenameInput 0 "Reference Image"
    $this RenameInput 1 "Transform Image" 102
}

# -----------------------------------------------------------------------------------------
# Execute
# ----------------------------------------------------------------------------------------

itcl::body bis_nonlinearbrainregister::Execute {  } {

    $this UpdateOutputFilenames   
    
    set ref [ $this GetInput ]
    set trn [ $this GetInputObject second_image ] 

    set f1 [ [ $this GetOutput ] cget -filename ]
    set ext [ file extension $f1 ]
    set f1 [ file rootname $f1 ]
    
    if { $ext == ".gz" } {
    	set f1 [ file rootname $f1 ]
	set ext "[ file extension $f1 ].gz"
    }

    set 5thpass [ $OptionsArray(5thpass) GetValue ]

    if { $5thpass != "none" } { 
	set iterations [ list 20 10 5 2.5 $5thpass ]
	set pass [ list 1stpass 2ndpass 3rdpass 4thpass "5thpass_$5thpass" ]
    } else { 
	set iterations [ list 20 10 5 2.5 ]
	set pass [ list 1stpass 2ndpass 3rdpass 4thpass ]
    }
    set numiterations [ llength $iterations ]

    set lin_alg [ bis_linearintensityregister [ pxvtable::vnewobj ] ]
    $lin_alg InitializeFromContainer 0 
    $lin_alg SetOptionValue mode affine
    $lin_alg SetOptionValue usegpu 0
    $lin_alg SetInputObject reference_image $ref
    $lin_alg SetInputObject transform_image $trn
    $lin_alg Execute 

    set xform [ $lin_alg GetOutputTransformation ]
    $xform Save "${f1}_affine.matr"

    set nl_alg [ bis_nonlinearintensityregister [ pxvtable::vnewobj ] ]
    $nl_alg InitializeFromContainer 0 
    $nl_alg SetInputObject reference_image $ref
    $nl_alg SetInputObject transform_image $trn
    $nl_alg SetOptionValue usegpu 0

    for { set i 0 } { $i<$numiterations } {incr i} {
    
	$nl_alg SetOptionValue spacing [ lindex $iterations $i ]
	$nl_alg SetOptionValue initialmode none
	$nl_alg SetOptionValue useinitial  1
	$nl_alg SetOptionValue resolution 1.05
	$nl_alg SetOptionValue numberoflevels 3
	$nl_alg SetInitialTransformation $xform
	$nl_alg Execute 

	set xform [ $nl_alg GetOutputTransformation ]
	$xform Save "${f1}_[ lindex $pass $i ].grd"
    }

    set reslice_alg [ bis_resliceimage [ pxvtable::vnewobj ] ]
    $reslice_alg InitializeFromContainer 0 
    $reslice_alg SetInput $ref
    $reslice_alg SetSecondInput $trn
    $reslice_alg SetTransformation $xform
    $reslice_alg Execute 

    set outimage [ $OutputsArray(output_image) GetObject ]
    $outimage ShallowCopyImage [ $reslice_alg GetOutput ] 
    $outimage CopyImageHeader [ $ref GetImageHeader ]

    return 1
}

itcl::body bis_nonlinearbrainregister::UpdateOutputFilenames { } {

    set f1 [ [ $this GetOutput ] cget -filename ]

    if { [ string length $f1 ] > 1 } {
	return 1
    }

    set f(0) [ $InputsArray(input_image) GetFileName ]
    set f(1) [ $InputsArray(second_image) GetFileName ]

    for { set i 0 } { $i <= 1 } { incr i } {
	set l($i) [ ::bis_common::SplitFileNameGZ $f($i) ]
	set f($i) [ file tail [ lindex $l($i) 0 ] ]
    }
    
    set fname [ file join [ file dirname $f(0) ] "$f(0)_$f(1)" ]
    
    set outlist [ $this CreateDefaultOutputFileList $fname ]
    set force 0;    if { $guimode == "managed" } {	set force 1    }    

    $OutputsArray(output_image) SetFileName "[ lindex $outlist 0 ][ $this GetExtension ]" $force

    return 1
}

# -----------------------------------------------------------------------------------------
#  This checks if executable is called (in this case bis_mediantemporalsmoothimage.tcl) if it is execute
# ----------------------------------------------------------------------------------------

 
if { [ file rootname $argv0 ] == [ file rootname [ info script ] ] } {
    # this is essentially the main function

    set alg [ bis_nonlinearbrainregister [ pxvtable::vnewobj ] ]
    $alg MainFunction 
}







