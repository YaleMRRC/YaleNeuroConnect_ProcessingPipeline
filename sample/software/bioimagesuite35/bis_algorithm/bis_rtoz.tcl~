#!/bin/sh
# the next line restarts using wish \
	exec vtk "$0" -- "$@"

lappend auto_path [ file dirname [ info script ]]
lappend auto_path [file join [file join [ file dirname [ info script ]] ".." ] base]
lappend auto_path [file join [file join [ file dirname [ info script ]] ".." ] apps]

package require bis_imagetoimagealgorithm 1.0
package provide bis_rtoz 1.0


itcl::class bis_rtoz {

	inherit bis_imagetoimagealgorithm

	 constructor { } {
	 $this Initialize
	 }

	public method Initialize { }
	public method Execute { }
	public method GetGUIName    { } { return "R-value to Z (fisher transform) value" }
}

# -----------------------------------------------------------------------------------------
# Initialize
# ----------------------------------------------------------------------------------------

itcl::body bis_rtoz::Initialize { } {

	PrintDebug "bis_rtoz::Initialize" 
	
	#commandswitch,description,shortdescription,optiontype,defaultvalue,valuerange,priority
   
	set options { }
	set defaultsuffix { "_Z" }
	set completionstatus "Done"
	set scriptname bis_rtoz
	set description "Converts r value to z value."
	set backwardcompatibility "N/A"
	set category "Functional Imaging"

	$this InitializeImageToImageAlgorithm
}

# -----------------------------------------------------------------------------------------
# Execute
# ----------------------------------------------------------------------------------------

itcl::body bis_rtoz::Execute {  } {

	PrintDebug "bis_rtoz::Execute"

	set ok [ pxtclvtkpxcontrib::ConditionalLoadLibrary  vtkbisConnectivityTCL vtkbisROICorrelation 0  ]
	if { $ok == 0 } {
	    set errormessage "Failed to load library vtkbisConnectivityTCL"
	    return 0
	}

	set image_in    [ $this GetInput ]
	set rtoz1 [ vtkbisRtoZ [ pxvtable::vnewobj ] ]	
	$rtoz1 SetInput $image_in
	$rtoz1 Update

	set outimage [ $OutputsArray(output_image) GetObject ]
	$outimage ShallowCopyImage [ $rtoz1 GetOutput ]
	$outimage CopyImageHeader [ $image_in GetImageHeader ]
	
	set comment [ format " [ $this GetCommandLine full ]" ]
	[ $outimage GetImageHeader ] AddComment "$comment $Log" 0
	
	$rtoz1 Delete
	
	return 1
}

# -----------------------------------------------------------------------------------------
#  This checks if executable is called (in this case bis_rtoz.tcl) if it is execute
# ----------------------------------------------------------------------------------------
 
if { [ file rootname $argv0 ] == [ file rootname [ info script ] ] } {
	# this is essentially the main function

	set alg [bis_rtoz [pxvtable::vnewobj]]
	$alg MainFunction 
}
